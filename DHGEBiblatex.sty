\DeclareFieldFormat{url}{\url{#1}}
\DeclareFieldFormat[book]{title}{\mkbibquote{#1}}

\DeclareNameFormat[book]{author}{%
  \namepartfamily
  \addcomma\space
  \namepartgiveni
  \ifthenelse{\value{listcount}=\value{liststop}}{
    \addcolon\space
  }{
    \addcomma
  }
}

\DeclareBibliographyDriver{book}{%
  \printnames{author}%
  \newunit\newblock
  \printfield{title}%
  \addcomma\space
  \newunit\newblock
  \iffieldundef{edition}{}{%
    \printfield{edition}%
    \addcomma\space
  }%
  \printlist{publisher}%
  \addcomma\space
  \newunit\newblock
  \printlist{location}%
  \addcomma\space
  \newunit\newblock
  \printfield{year}%
}

\newlength{\fieldlength}
\newlength{\urlbreaklength}
\setlength{\urlbreaklength}{10cm}
\DeclareBibliographyDriver{online}{%
  \printnames{author}%
  \addcolon\space
  \newunit\newblock
  \printfield{title}%
  \adddot\space
  Abgerufen am\space
  \printfield{note}%
  \newunit\newblock
  \space
  \newline
  von\addcolon\
  \printfield[url]{url}%
  \addcomma\space
  \printlist{location}%
  \newunit\newblock
  \addcomma\space
  \printfield{year}%
}

\DeclareBibliographyDriver{standard}{%
  \printnames{author}%
  \addcolon\space
  \newunit\newblock
  \printfield{title}%
  \adddot\space
  \newunit\newblock\newline
  \printfield{number}%
  \addcomma
  \newunit\newblock
  \printlist{location}%
  \addcomma
  \newunit\newblock
  \printfield{month}%
  \space
  \printfield{year}%
}